# Copy to `.env` and fill in. NEVER commit the real `.env` (Ch 12 §12.2).
# These live only on the API host in production (Render); the client gets only NEXT_PUBLIC_*.

# ---- API (server-side only) ----
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"
JWT_ACCESS_SECRET="generate-a-long-random-string"
JWT_REFRESH_SECRET="generate-a-DIFFERENT-long-random-string"
ANTHROPIC_API_KEY="sk-ant-..."
DEMO_MODE="true"          # true → serve cached AI parses at $0 (Ch 9 §9.5)
PORT="4000"

# ---- Web (public — safe to expose to the browser) ----
NEXT_PUBLIC_API_URL="http://localhost:4000/api/v1"
